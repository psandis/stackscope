{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stackscope.local/schemas/blueprint.schema.json",
  "title": "Stackscope Blueprint",
  "type": "object",
  "required": ["name", "root_path", "components", "relationships", "evidence"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string"
    },
    "root_path": {
      "type": "string"
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relationship"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "required": ["id", "name", "type", "technology", "source_path", "tags", "metadata"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "technology": {
          "type": ["string", "null"]
        },
        "source_path": {
          "type": ["string", "null"]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metadata": {
          "type": "object"
        }
      }
    },
    "relationship": {
      "type": "object",
      "required": ["source", "target", "type", "label", "metadata"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "label": {
          "type": ["string", "null"]
        },
        "metadata": {
          "type": "object"
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["kind", "source_path", "details"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string"
        },
        "source_path": {
          "type": "string"
        },
        "details": {
          "type": "object"
        }
      }
    }
  }
}
